<% const currentPage = 'enrollment'; %>
<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<%- include('../partials/sidebar') %>

<style>
  @keyframes waveformPulse { 0%, 100% { transform: scaleY(0.3); } 50% { transform: scaleY(1); } }
  .waveform-bar { transition: background-color 0.3s; }
  .waveform-bar.animating:nth-child(1) { animation: waveformPulse 0.8s ease-in-out infinite 0s; }
  .waveform-bar.animating:nth-child(2) { animation: waveformPulse 0.8s ease-in-out infinite 0.15s; }
  .waveform-bar.animating:nth-child(3) { animation: waveformPulse 0.8s ease-in-out infinite 0.3s; }
  .waveform-bar.animating:nth-child(4) { animation: waveformPulse 0.8s ease-in-out infinite 0.45s; }
  .waveform-bar.animating:nth-child(5) { animation: waveformPulse 0.8s ease-in-out infinite 0.6s; }
  @keyframes checkDraw { 0% { stroke-dashoffset: 30; } 100% { stroke-dashoffset: 0; } }
  .check-animated path { stroke-dasharray: 30; stroke-dashoffset: 30; animation: checkDraw 0.5s ease forwards 0.2s; }
  @keyframes confetti { 0% { transform: translateY(0) rotate(0deg); opacity: 1; } 100% { transform: translateY(-60px) rotate(720deg); opacity: 0; } }
</style>

<main class="lg:ml-[260px] pt-16 min-h-screen">
  <div class="p-4 sm:p-6 lg:p-8 page-enter">

    <!-- Page Header -->
    <div class="mb-8">
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">Voice Enrollment</h1>
      <p class="mt-1 text-sm text-slate-400">Register your voice for contactless attendance</p>
    </div>

    <!-- Progress Steps -->
    <div class="max-w-xl mx-auto mb-10">
      <div class="flex items-center justify-between relative">
        <!-- Connecting Lines -->
        <div class="absolute top-5 left-[calc(16.67%)] right-[calc(16.67%)] h-0.5 bg-white/[0.08]"></div>
        <div id="enrollProgressLine" class="absolute top-5 left-[calc(16.67%)] h-0.5 bg-gradient-to-r from-indigo-500 to-violet-500 transition-all duration-700 ease-out" style="width: 0%"></div>

        <!-- Step 1 -->
        <div class="flex flex-col items-center relative z-10" id="enrollStep1Indicator">
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center text-sm font-bold text-white shadow-lg shadow-indigo-500/30 transition-all duration-300" id="enrollStep1Circle">
            <span id="enrollStep1Num">1</span>
          </div>
          <span class="mt-2 text-xs font-semibold text-indigo-400" id="enrollStep1Label">Prepare</span>
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col items-center relative z-10" id="enrollStep2Indicator">
          <div class="w-10 h-10 rounded-full bg-white/[0.06] border border-white/[0.1] flex items-center justify-center text-sm font-bold text-slate-500 transition-all duration-300" id="enrollStep2Circle">
            <span id="enrollStep2Num">2</span>
          </div>
          <span class="mt-2 text-xs font-semibold text-slate-500" id="enrollStep2Label">Record</span>
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col items-center relative z-10" id="enrollStep3Indicator">
          <div class="w-10 h-10 rounded-full bg-white/[0.06] border border-white/[0.1] flex items-center justify-center text-sm font-bold text-slate-500 transition-all duration-300" id="enrollStep3Circle">
            <span id="enrollStep3Num">3</span>
          </div>
          <span class="mt-2 text-xs font-semibold text-slate-500" id="enrollStep3Label">Complete</span>
        </div>
      </div>
    </div>

    <!-- Step Content Container -->
    <div class="max-w-xl mx-auto">

      <!-- Step 1: Prepare -->
      <div id="enrollStepContent1" class="glass-card rounded-2xl border border-white/[0.06] bg-white/[0.03] backdrop-blur-xl p-6 sm:p-8 text-center">
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-indigo-500/20 to-violet-600/20 border border-indigo-500/10 flex items-center justify-center mx-auto mb-5">
          <svg class="w-8 h-8 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h2 class="text-xl font-bold text-white mb-3">Before You Begin</h2>
        <p class="text-sm text-slate-400 mb-6 max-w-md mx-auto">You'll record <strong class="text-white">3 voice samples</strong> to create your unique voiceprint. This takes about 2 minutes.</p>

        <div class="space-y-3 text-left max-w-sm mx-auto mb-8">
          <div class="flex items-start gap-3 p-3 rounded-xl bg-white/[0.03] border border-white/[0.04]">
            <div class="w-7 h-7 rounded-lg bg-indigo-500/15 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-white">Find a quiet environment</p>
              <p class="text-xs text-slate-500 mt-0.5">Background noise may affect accuracy</p>
            </div>
          </div>
          <div class="flex items-start gap-3 p-3 rounded-xl bg-white/[0.03] border border-white/[0.04]">
            <div class="w-7 h-7 rounded-lg bg-violet-500/15 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-white">Speak your full name clearly</p>
              <p class="text-xs text-slate-500 mt-0.5">Say your name naturally, at a normal pace</p>
            </div>
          </div>
          <div class="flex items-start gap-3 p-3 rounded-xl bg-white/[0.03] border border-white/[0.04]">
            <div class="w-7 h-7 rounded-lg bg-purple-500/15 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-white">Record 3 samples</p>
              <p class="text-xs text-slate-500 mt-0.5">Multiple recordings improve recognition accuracy</p>
            </div>
          </div>
        </div>

        <button id="enrollStartBtn" class="btn-primary inline-flex items-center gap-2 px-8 py-3 rounded-xl bg-gradient-to-r from-indigo-500 to-violet-600 text-white font-semibold text-sm shadow-lg shadow-indigo-500/25 hover:shadow-xl hover:shadow-indigo-500/30 hover:from-indigo-400 hover:to-violet-500 active:scale-[0.98] transition-all duration-200">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          Begin Enrollment
        </button>
      </div>

      <!-- Step 2: Record -->
      <div id="enrollStepContent2" class="hidden glass-card rounded-2xl border border-white/[0.06] bg-white/[0.03] backdrop-blur-xl p-6 sm:p-8 text-center">
        <h2 class="text-xl font-bold text-white mb-2">Record Your Voice</h2>
        <p class="text-sm text-slate-400 mb-6">
          Sample <span id="enrollCurrentSample" class="text-indigo-400 font-semibold">1</span> of <span class="text-white font-semibold">3</span>
        </p>

        <!-- Waveform -->
        <div class="flex items-end justify-center gap-1.5 h-16 mb-6" id="enrollWaveform">
          <div class="waveform-bar w-2 h-4 rounded-full bg-indigo-500/30" style="transform: scaleY(0.3);"></div>
          <div class="waveform-bar w-2 h-8 rounded-full bg-indigo-500/30" style="transform: scaleY(0.3);"></div>
          <div class="waveform-bar w-2 h-12 rounded-full bg-indigo-500/30" style="transform: scaleY(0.3);"></div>
          <div class="waveform-bar w-2 h-8 rounded-full bg-indigo-500/30" style="transform: scaleY(0.3);"></div>
          <div class="waveform-bar w-2 h-4 rounded-full bg-indigo-500/30" style="transform: scaleY(0.3);"></div>
        </div>

        <!-- Enrollment Mic Button -->
        <div class="relative inline-block mb-6">
          <button
            id="enrollMicBtn"
            class="mic-button w-24 h-24 rounded-full bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center shadow-xl shadow-indigo-500/25 hover:shadow-indigo-500/40 hover:scale-105 active:scale-95 transition-all duration-300 focus:outline-none"
            aria-label="Start recording"
          >
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
            </svg>
          </button>
        </div>

        <p id="enrollRecordState" class="text-sm font-medium text-slate-400 mb-6">Tap the mic to start recording</p>

        <!-- Per-attempt feedback -->
        <div id="enrollAttemptFeedback" class="space-y-2 max-w-xs mx-auto">
          <div id="enrollAttempt1" class="flex items-center gap-3 p-2.5 rounded-lg bg-white/[0.02] border border-white/[0.04] transition-all duration-300">
            <div class="w-6 h-6 rounded-full bg-white/[0.06] flex items-center justify-center text-xs font-bold text-slate-500" id="enrollAttempt1Icon">1</div>
            <span class="text-sm text-slate-500" id="enrollAttempt1Text">Sample 1 - Waiting</span>
          </div>
          <div id="enrollAttempt2" class="flex items-center gap-3 p-2.5 rounded-lg bg-white/[0.02] border border-white/[0.04] transition-all duration-300">
            <div class="w-6 h-6 rounded-full bg-white/[0.06] flex items-center justify-center text-xs font-bold text-slate-500" id="enrollAttempt2Icon">2</div>
            <span class="text-sm text-slate-500" id="enrollAttempt2Text">Sample 2 - Waiting</span>
          </div>
          <div id="enrollAttempt3" class="flex items-center gap-3 p-2.5 rounded-lg bg-white/[0.02] border border-white/[0.04] transition-all duration-300">
            <div class="w-6 h-6 rounded-full bg-white/[0.06] flex items-center justify-center text-xs font-bold text-slate-500" id="enrollAttempt3Icon">3</div>
            <span class="text-sm text-slate-500" id="enrollAttempt3Text">Sample 3 - Waiting</span>
          </div>
        </div>
      </div>

      <!-- Step 3: Complete -->
      <div id="enrollStepContent3" class="hidden glass-card rounded-2xl border border-white/[0.06] bg-white/[0.03] backdrop-blur-xl p-6 sm:p-8 text-center">
        <div class="w-20 h-20 rounded-full bg-gradient-to-br from-emerald-500 to-green-600 flex items-center justify-center mx-auto mb-6 shadow-2xl shadow-emerald-500/30">
          <svg class="check-animated w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h2 class="text-2xl font-extrabold text-white mb-2">Enrollment Complete!</h2>
        <p class="text-sm text-slate-400 mb-6">Your voice profile has been successfully created.</p>

        <div class="max-w-xs mx-auto space-y-3 mb-8">
          <div class="flex items-center justify-between p-3 rounded-xl bg-white/[0.03] border border-white/[0.04]">
            <span class="text-sm text-slate-400">Enrolled Phrase</span>
            <span class="text-sm font-semibold text-white" id="enrollResultPhrase">Full Name</span>
          </div>
          <div class="flex items-center justify-between p-3 rounded-xl bg-white/[0.03] border border-white/[0.04]">
            <span class="text-sm text-slate-400">Average Confidence</span>
            <span class="text-sm font-semibold text-emerald-400" id="enrollResultConfidence">0%</span>
          </div>
          <div class="flex items-center justify-between p-3 rounded-xl bg-white/[0.03] border border-white/[0.04]">
            <span class="text-sm text-slate-400">Samples Recorded</span>
            <span class="text-sm font-semibold text-white" id="enrollResultSamples">3/3</span>
          </div>
        </div>

        <a href="/attendance" id="enrollGoToAttendance" class="btn-primary inline-flex items-center gap-2 px-8 py-3 rounded-xl bg-gradient-to-r from-indigo-500 to-violet-600 text-white font-semibold text-sm shadow-lg shadow-indigo-500/25 hover:shadow-xl hover:shadow-indigo-500/30 active:scale-[0.98] transition-all duration-200">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
          Go to Attendance Station
        </a>
      </div>

    </div>
  </div>
</main>

<script src="/js/speechRecognition.js"></script>
<script src="/js/voiceEnrollment.js"></script>
<%- include('../partials/footer') %>
