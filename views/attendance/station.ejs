<% const currentPage = 'attendance'; %>
<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<%- include('../partials/sidebar') %>

<style>
  @keyframes pulseRing { 0% { transform: scale(1); opacity: 0.6; } 100% { transform: scale(2.2); opacity: 0; } }
  @keyframes micPulse { 0%, 100% { box-shadow: 0 0 0 0 rgba(99,102,241,0.4); } 50% { box-shadow: 0 0 0 20px rgba(99,102,241,0); } }
  @keyframes successPop { 0% { transform: scale(0.8); opacity: 0; } 50% { transform: scale(1.05); } 100% { transform: scale(1); opacity: 1; } }
  .mic-button.listening { animation: micPulse 2s ease-in-out infinite; }
  .mic-button.listening .mic-pulse-ring { animation: pulseRing 1.5s cubic-bezier(0.215, 0.61, 0.355, 1) infinite; }
  .mic-button.listening .mic-pulse-ring:nth-child(2) { animation-delay: 0.5s; }
  .mic-button.processing { opacity: 0.7; cursor: wait; }
  .mic-button.success { background: linear-gradient(135deg, #10b981, #059669) !important; }
  .mic-button.error { background: linear-gradient(135deg, #ef4444, #dc2626) !important; }
  .validation-enter { animation: successPop 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
</style>

<main class="lg:ml-[260px] pt-16 min-h-screen">
  <div class="p-4 sm:p-6 lg:p-8 page-enter">

    <!-- Page Header + Session Selector -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
      <div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-white">Attendance Station</h1>
        <p class="mt-1 text-sm text-slate-400">Mark attendance using voice recognition</p>
      </div>
    </div>

    <!-- Session Selector -->
    <div class="glass-card rounded-2xl border border-white/[0.06] bg-white/[0.03] backdrop-blur-xl p-4 mb-8">
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3">
        <label for="sessionSelector" class="text-sm font-medium text-slate-300 whitespace-nowrap">Active Session:</label>
        <select id="sessionSelector" class="input-field flex-1 w-full sm:w-auto px-4 py-2.5 rounded-xl border border-white/[0.08] bg-white/[0.04] text-white text-sm outline-none focus:border-indigo-500/50 focus:ring-2 focus:ring-indigo-500/20 transition-all">
          <option value="" class="bg-[#1e293b]">Select a session...</option>
        </select>
        <div id="sessionStatusBadge" class="hidden">
          <span class="badge badge-success inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-emerald-500/15 text-emerald-400 border border-emerald-500/20">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            Live
          </span>
        </div>
      </div>
    </div>

    <!-- Mic Hero Section -->
    <div class="flex flex-col items-center justify-center py-8 sm:py-12">

      <!-- Browser support warning -->
      <div id="speechApiWarning" class="hidden mb-6 w-full max-w-md">
        <div class="alert alert-warning px-4 py-3 rounded-xl border border-amber-500/20 bg-amber-500/10 text-amber-300 text-sm flex items-center gap-3">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <span>Your browser does not support the Web Speech API. Please use Chrome, Edge, or Safari.</span>
        </div>
      </div>

      <!-- Mic Button Area -->
      <div class="relative mb-6">
        <!-- Pulse Rings (visible during listening) -->
        <div class="mic-pulse-ring absolute inset-0 rounded-full border-2 border-indigo-500/30 pointer-events-none opacity-0"></div>
        <div class="mic-pulse-ring absolute inset-0 rounded-full border-2 border-indigo-500/20 pointer-events-none opacity-0"></div>

        <!-- The Mic Button -->
        <button
          id="micButton"
          class="mic-button relative w-[140px] h-[140px] rounded-full bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center shadow-2xl shadow-indigo-500/30 hover:shadow-indigo-500/50 hover:scale-105 active:scale-95 transition-all duration-300 focus:outline-none focus-visible:ring-4 focus-visible:ring-indigo-500/40 disabled:opacity-50 disabled:cursor-not-allowed"
          aria-label="Tap to start voice recognition"
          disabled
        >
          <!-- Mic Icon -->
          <svg id="micIcon" class="w-12 h-12 text-white transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
          </svg>
          <!-- Processing Spinner (hidden by default) -->
          <svg id="micSpinner" class="hidden w-12 h-12 text-white animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
          </svg>
          <!-- Success Checkmark (hidden by default) -->
          <svg id="micSuccess" class="hidden w-14 h-14 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
          </svg>
          <!-- Error X (hidden by default) -->
          <svg id="micError" class="hidden w-14 h-14 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- State Text -->
      <p id="micStateText" class="text-lg font-semibold text-slate-400 mb-2 transition-colors duration-300">Select a session to begin</p>
      <p id="processingTime" class="text-xs text-slate-600 hidden">Processing time: <span id="processingTimeValue">0</span>ms</p>

      <!-- Transcript Display -->
      <div id="transcriptDisplay" class="hidden w-full max-w-lg mt-6">
        <div class="glass-card rounded-2xl border border-white/[0.06] bg-white/[0.03] backdrop-blur-xl p-5">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></div>
            <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">Transcript</span>
          </div>
          <p id="interimText" class="text-sm text-slate-500 italic min-h-[1.5rem]"></p>
          <p id="finalText" class="text-base text-white font-medium mt-1 min-h-[1.5rem]"></p>
        </div>
      </div>
    </div>

    <!-- Validation Panel -->
    <div id="validationPanel" class="hidden max-w-lg mx-auto mb-8">
      <!-- Success State -->
      <div id="validationSuccess" class="hidden validation-enter rounded-2xl border border-emerald-500/20 bg-emerald-500/[0.06] backdrop-blur-xl p-6">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-emerald-500/20 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-emerald-400">Attendance Marked!</h3>
            <p class="text-sm text-slate-300 mt-1">Identified: <span id="validationUserName" class="font-semibold text-white">---</span></p>
            <p class="text-xs text-slate-500 mt-1">Confidence: <span id="validationConfidence" class="text-emerald-400 font-semibold">0%</span></p>
          </div>
        </div>
      </div>

      <!-- Retry State -->
      <div id="validationRetry" class="hidden validation-enter rounded-2xl border border-amber-500/20 bg-amber-500/[0.06] backdrop-blur-xl p-6">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-amber-500/20 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-amber-400">Low Confidence Match</h3>
            <p class="text-sm text-slate-300 mt-1">Please try again more clearly.</p>
            <p class="text-xs text-slate-500 mt-1">Attempt: <span id="validationAttemptCount">1</span>/3</p>
            <button id="validationRetryBtn" class="mt-3 px-4 py-2 text-xs font-semibold rounded-lg bg-amber-500/15 text-amber-400 border border-amber-500/20 hover:bg-amber-500/25 transition-all duration-200">Try Again</button>
          </div>
        </div>
      </div>

      <!-- Error State -->
      <div id="validationError" class="hidden validation-enter rounded-2xl border border-red-500/20 bg-red-500/[0.06] backdrop-blur-xl p-6">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-red-500/20 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-red-400">Not Recognized</h3>
            <p class="text-sm text-slate-300 mt-1">Voice could not be matched to any enrolled user.</p>
            <button id="validationErrorRetryBtn" class="mt-3 px-4 py-2 text-xs font-semibold rounded-lg bg-red-500/15 text-red-400 border border-red-500/20 hover:bg-red-500/25 transition-all duration-200">Retry</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Recent Verifications -->
    <div class="max-w-lg mx-auto">
      <div class="glass-card rounded-2xl border border-white/[0.06] bg-white/[0.03] backdrop-blur-xl p-5">
        <h3 class="text-sm font-bold text-white mb-4 flex items-center gap-2">
          <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Recent Verifications
        </h3>
        <div id="recentVerifications" class="space-y-2">
          <p class="text-center text-xs text-slate-600 py-4">No verifications yet for this session</p>
        </div>
      </div>
    </div>

  </div>
</main>

<script src="/js/speechRecognition.js"></script>
<script src="/js/attendanceStation.js"></script>
<%- include('../partials/footer') %>
