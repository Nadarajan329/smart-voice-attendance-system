<%- include('../partials/header') %>

<!-- Animated Background -->
<div class="fixed inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
  <!-- Gradient Orbs -->
  <div class="absolute -top-40 -left-40 w-96 h-96 bg-indigo-600/20 rounded-full animate-[orbFloat1_15s_ease-in-out_infinite]" style="filter: blur(120px); -webkit-filter: blur(120px);"></div>
  <div class="absolute top-1/3 -right-32 w-80 h-80 bg-violet-600/15 rounded-full animate-[orbFloat2_20s_ease-in-out_infinite]" style="filter: blur(100px); -webkit-filter: blur(100px);"></div>
  <div class="absolute -bottom-20 left-1/3 w-72 h-72 bg-purple-600/10 rounded-full animate-[orbFloat3_18s_ease-in-out_infinite]" style="filter: blur(80px); -webkit-filter: blur(80px);"></div>
  <!-- Subtle Grid -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(99,102,241,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(99,102,241,0.03)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
</div>

<style>
  @keyframes orbFloat1 { 0%, 100% { transform: translate(0, 0) scale(1); } 33% { transform: translate(30px, -20px) scale(1.05); } 66% { transform: translate(-20px, 15px) scale(0.95); } }
  @keyframes orbFloat2 { 0%, 100% { transform: translate(0, 0) scale(1); } 50% { transform: translate(-40px, 25px) scale(1.1); } }
  @keyframes orbFloat3 { 0%, 100% { transform: translate(0, 0); } 40% { transform: translate(25px, -30px); } 80% { transform: translate(-15px, 20px); } }
  @keyframes spinSlow { to { transform: rotate(360deg); } }
  .input-wrapper input:focus ~ .input-label,
  .input-wrapper input:not(:placeholder-shown) ~ .input-label {
    transform: translateY(-1.7rem) scale(0.85);
    color: #818cf8;
  }
  .input-label {
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: left;
  }
</style>

<main class="relative min-h-screen flex items-center justify-center px-4 py-12">
  <!-- Login Card -->
  <div class="w-full max-w-md page-enter">
    <!-- Logo and Brand -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-indigo-500 to-violet-600 shadow-2xl shadow-indigo-500/30 mb-5 relative">
        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
        </svg>
        <!-- Decorative ring -->
        <div class="absolute inset-0 rounded-2xl border border-white/20 animate-[spinSlow_20s_linear_infinite]"></div>
      </div>
      <h1 class="text-3xl font-extrabold bg-gradient-to-r from-indigo-400 via-violet-400 to-purple-400 bg-clip-text text-transparent">VoiceTrack</h1>
      <p class="mt-2 text-sm text-slate-500 tracking-wide">Contactless Voice Attendance</p>
    </div>

    <!-- Glass Card Form -->
    <div class="glass-card relative rounded-2xl border border-white/[0.08] bg-white/[0.03] backdrop-blur-2xl p-8 shadow-2xl shadow-black/20">
      <!-- Top accent line -->
      <div class="absolute top-0 left-6 right-6 h-px bg-gradient-to-r from-transparent via-indigo-500/50 to-transparent"></div>

      <form id="loginForm" novalidate>
        <!-- Error message -->
        <div id="loginError" class="hidden mb-5 px-4 py-3 rounded-xl border border-red-500/20 bg-red-500/10 text-red-400 text-sm flex items-center gap-3" role="alert">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span id="loginErrorText">Invalid credentials. Please try again.</span>
        </div>

        <!-- Email -->
        <div class="mb-5">
          <div class="input-wrapper relative">
            <div class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none z-10">
              <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <input
              type="email"
              id="loginEmail"
              name="email"
              placeholder=" "
              autocomplete="email"
              required
              class="input-field w-full pl-11 pr-4 pt-5 pb-2 rounded-xl border border-white/[0.08] bg-white/[0.04] text-white text-sm outline-none focus:border-indigo-500/50 focus:bg-white/[0.06] focus:ring-2 focus:ring-indigo-500/20 transition-all duration-200 peer"
            />
            <label for="loginEmail" class="input-label absolute left-11 top-1/2 -translate-y-1/2 text-slate-500 text-sm pointer-events-none peer-focus:translate-y-[-1.7rem] peer-focus:scale-[0.85] peer-focus:text-indigo-400 peer-[:not(:placeholder-shown)]:translate-y-[-1.7rem] peer-[:not(:placeholder-shown)]:scale-[0.85]">Email address</label>
          </div>
        </div>

        <!-- Password -->
        <div class="mb-5">
          <div class="input-wrapper relative">
            <div class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none z-10">
              <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            </div>
            <input
              type="password"
              id="loginPassword"
              name="password"
              placeholder=" "
              autocomplete="current-password"
              required
              class="input-field w-full pl-11 pr-12 pt-5 pb-2 rounded-xl border border-white/[0.08] bg-white/[0.04] text-white text-sm outline-none focus:border-indigo-500/50 focus:bg-white/[0.06] focus:ring-2 focus:ring-indigo-500/20 transition-all duration-200 peer"
            />
            <label for="loginPassword" class="input-label absolute left-11 top-1/2 -translate-y-1/2 text-slate-500 text-sm pointer-events-none peer-focus:translate-y-[-1.7rem] peer-focus:scale-[0.85] peer-focus:text-indigo-400 peer-[:not(:placeholder-shown)]:translate-y-[-1.7rem] peer-[:not(:placeholder-shown)]:scale-[0.85]">Password</label>
            <button type="button" id="loginPasswordToggle" class="absolute right-3.5 top-1/2 -translate-y-1/2 text-slate-500 hover:text-slate-300 transition-colors z-10" aria-label="Toggle password visibility">
              <svg id="passwordEyeOpen" class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              <svg id="passwordEyeClosed" class="w-[18px] h-[18px] hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
            </button>
          </div>
        </div>

        <!-- Remember me -->
        <div class="flex items-center justify-between mb-6">
          <label class="flex items-center gap-2.5 cursor-pointer group" for="loginRemember">
            <div class="relative">
              <input type="checkbox" id="loginRemember" class="sr-only peer" />
              <div class="w-5 h-5 rounded-md border border-white/[0.12] bg-white/[0.04] peer-checked:bg-indigo-500 peer-checked:border-indigo-500 transition-all duration-200 flex items-center justify-center peer-focus-visible:ring-2 peer-focus-visible:ring-indigo-500/40">
                <svg class="w-3 h-3 text-white opacity-0 peer-checked:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
              </div>
            </div>
            <span class="text-sm text-slate-400 group-hover:text-slate-300 transition-colors">Remember me</span>
          </label>
          <a href="#" class="text-sm text-indigo-400 hover:text-indigo-300 transition-colors">Forgot password?</a>
        </div>

        <!-- Submit -->
        <button
          type="submit"
          id="loginSubmitBtn"
          class="btn-primary relative w-full py-3 px-4 rounded-xl bg-gradient-to-r from-indigo-500 to-violet-600 text-white font-semibold text-sm shadow-lg shadow-indigo-500/25 hover:shadow-xl hover:shadow-indigo-500/30 hover:from-indigo-400 hover:to-violet-500 active:scale-[0.98] transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed overflow-hidden"
        >
          <span id="loginBtnText" class="flex items-center justify-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
            Sign In
          </span>
          <span id="loginBtnLoading" class="hidden absolute inset-0 flex items-center justify-center gap-2">
            <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/></svg>
            Signing in...
          </span>
        </button>
      </form>

      <!-- Divider -->
      <div class="mt-6 flex items-center gap-3">
        <div class="flex-1 h-px bg-white/[0.06]"></div>
        <span class="text-xs text-slate-600">Secure Authentication</span>
        <div class="flex-1 h-px bg-white/[0.06]"></div>
      </div>

      <!-- Security badge -->
      <div class="mt-4 flex items-center justify-center gap-2 text-slate-600">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        <span class="text-[11px]">256-bit encrypted connection</span>
      </div>
    </div>

    <!-- Footer text -->
    <p class="mt-6 text-center text-xs text-slate-600">
      &copy; 2026 VoiceTrack. Smart Voice Based Attendance System.
    </p>
  </div>
</main>

<script src="/js/auth.js"></script>
</body>
</html>
