<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Smart Voice Based Attendance System - Contactless attendance tracking using speech recognition">
  <meta name="theme-color" content="#0f172a">
  <title><%= typeof title !== 'undefined' ? title : 'VoiceTrack' %> | VoiceTrack</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <style>
    /* Critical inline styles for FOUC prevention */
    body { background-color: #0f172a; color: #e2e8f0; font-family: 'Inter', system-ui, sans-serif; }
    .page-enter { animation: pageEnter 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; transform: translateY(8px); }
    @keyframes pageEnter { to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body class="bg-[#0f172a] text-[#e2e8f0] min-h-screen font-['Inter'] antialiased">
