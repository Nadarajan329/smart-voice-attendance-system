# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/voice_attendance

# JWT Secrets (change these in production!)
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_in_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# SMTP Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@voiceattendance.com

# Twilio SMS (Optional)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# Google Cloud Speech-to-Text (Optional)
GOOGLE_APPLICATION_CREDENTIALS=

# Voice Recognition Settings
VOICE_CONFIDENCE_THRESHOLD=0.75
VOICE_MAX_ENROLLMENT_ATTEMPTS=5
VOICE_REQUIRED_SUCCESSFUL_ENROLLMENTS=3

# Attendance Settings
LATE_THRESHOLD_MINUTES=15
ABSENCE_ALERT_THRESHOLD=3

# Admin Default Account
ADMIN_EMAIL=admin@voiceattendance.com
ADMIN_PASSWORD=Admin@123456
